# DCI MCP Server Configuration
# Copy this file to .env and fill in your DCI credentials

# DCI Authentication (choose one method)

# Method 1: API Key Authentication
# DCI_CLIENT_ID=<client_type>/<client_id>
# DCI_API_SECRET=<api_secret>

# Method 2: User ID/Password (alternative to API key)
# DCI_LOGIN=foo
# DCI_PASSWORD=bar

# Optional: Override DCI API URL (default: https://api.distributed-ci.io)
# DCI_CS_URL=https://api.distributed-ci.io

# Google Drive Integration (optional)
# Path to Google OAuth2 credentials JSON file
# GOOGLE_CREDENTIALS_PATH=credentials.json

# Path to store/load OAuth2 token (default: token.json)
# GOOGLE_TOKEN_PATH=token.json

# Jira Integration (optional)
# Jira API token for ticket data collection
# JIRA_API_TOKEN=your_jira_api_token_here

# Jira server URL (default: https://redhat.atlassian.net)
# JIRA_URL=https://redhat.atlassian.net

# Jira email address (required for Jira Cloud basic auth; omit for Data Center token auth)
# JIRA_EMAIL=you@example.com

# Optional: custom field id for partner/customer on Closed Loop issues (used by
# scripts/fill_review_queue_corrective_measures.py to populate CSV column partner_or_customer)
# JIRA_PARTNER_CUSTOM_FIELD=customfield_12345

# Enable Jira write operations (create/update tickets, add comments)
# Disabled by default for safety. Set to "true" to enable.
# JIRA_WRITE_ENABLED=true

# GitHub Integration (optional)
# GitHub personal access token for issue/PR search
# Get your token from: https://github.com/settings/tokens
# GITHUB_TOKEN=your_github_token_here

# Red Hat Support Case Integration (optional)
# Red Hat API offline token for support case access
# Get your token from: https://access.redhat.com/management/api
# OFFLINE_TOKEN=your_offline_token_here
